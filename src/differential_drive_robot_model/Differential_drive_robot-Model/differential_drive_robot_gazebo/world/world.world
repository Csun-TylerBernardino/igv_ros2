<?xml version="1.0" ?>
<sdf version="1.4">
  <world name="default">

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Camera positioned to see the robot clearly at spawn -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>2.0 -2.0 1.5 0.0 0.4 2.45</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>

  </world>
</sdf>
